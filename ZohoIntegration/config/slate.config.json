{
  "name": "zoho-integration-app",
  "version": "1.0.0",
  "hosting": {
    "type": "static",
    "source": "dist",
    "singlePageApp": true
  },
  "headers": {
    "/*": {
      "Content-Security-Policy": "frame-ancestors 'self' https://*.zoho.com https://*.zohocrm.com",
      "X-Frame-Options": "ALLOW-FROM https://crm.zoho.com",
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    }
  },
  "rewrites": [
    {
      "source": "/**",
      "destination": "/index.html"
    }
  ],
  "environment": {
    "VITE_API_MODE": "live"
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite"
}
