# Dimentions Audit Authenticator — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# For Vite (frontend), prefix with VITE_:
# For Node scripts, use without prefix.

# ─────────────────────────────────────────────────────────────
# ZOHO OAUTH APP CREDENTIALS (from Zoho API Console)
# console.zoho.com → API → OAuth → Your App
# ─────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=your_zoho_client_id_here
VITE_ZOHO_CLIENT_ID=your_zoho_client_id_here

ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
# (never expose client_secret to browser — backend/scripts only)

# Long-lived refresh token (generated via OAuth consent screen)
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here
VITE_ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here

# Your Zoho organization ID
ZOHO_ORG_ID=your_org_id_here
VITE_ZOHO_ORG_ID=your_org_id_here

# ─────────────────────────────────────────────────────────────
# ZOHO API ENDPOINTS (usually don't change)
# ─────────────────────────────────────────────────────────────
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# ─────────────────────────────────────────────────────────────
# DEFAULTS
# ─────────────────────────────────────────────────────────────
DEFAULT_MODULE=Products
DEFAULT_ENVIRONMENT=production

# ─────────────────────────────────────────────────────────────
# TOKEN REFRESH SCRIPT (one-time use)
# ─────────────────────────────────────────────────────────────
# Used only when running scripts/get-refresh-token.js
# Get auth code from: https://accounts.zoho.com/oauth/v2/auth
ZOHO_AUTH_CODE=one_time_auth_code_from_zoho_oauth_consent_screen
