{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://crm.zoho.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.zoho.com https://*.zohoapis.com"
        }
      ]
    }
  ]
}
